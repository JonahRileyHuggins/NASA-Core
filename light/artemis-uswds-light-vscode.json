{
    "name": "Artemis USWDS Light",
    "type": "light",
    "colors": {
        "editor.background": "#FFFFFF",
        "editor.foreground": "#000000",
        "editor.lineHighlightBackground": "#f5f5f5",
        "editor.selectionBackground": "#e8e8e8",
        "editorLineNumber.foreground": "#71767a",
        "editorLineNumber.activeForeground": "#ffffff",
        "statusBar.background": "#f5f5f5",
        "statusBar.foreground": "#1a1a1a",
        "panel.border": "#e8e8e8",
        "editorGroup.border": "#e8e8e8",
        "editorError.foreground": "#e31c3d",
        "editorWarning.foreground": "#f15a29",
        "editorCursor.foreground": "#000000",
        "terminal.background": "#FFFFFF",
        "terminal.foreground": "#000000",
        "terminalCursor.foreground": "#000000",
        "terminalCursor.background": "#FFFFFF"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#71767a",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#f15a29"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "constant.other.symbol",
                "constant.character"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "variable",
                "variable.parameter",
                "variable.other",
                "entity.name.variable",
                "support.variable"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "keyword",
                "storage",
                "storage.type"
            ],
            "settings": {
                "foreground": "#ed1c24"
            }
        },
        {
            "scope": [
                "keyword.control",
                "keyword.operator.word"
            ],
            "settings": {
                "foreground": "#0066b3"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#333333"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class",
                "storage.type.class"
            ],
            "settings": {
                "foreground": "#0066b3"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#2e7bcf"
            }
        },
        {
            "scope": [
                "keyword.other.import",
                "keyword.other.namespace",
                "storage.modifier.import",
                "storage.modifier.package"
            ],
            "settings": {
                "foreground": "#0066b3"
            }
        },
        {
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#e31c3d"
            }
        },
        {
            "scope": [
                "markup.bold",
                "meta.annotation.todo",
                "keyword.other.todo"
            ],
            "settings": {
                "foreground": "#FFFFFF",
                "background": "#f15a29"
            }
        }
    ]
}
